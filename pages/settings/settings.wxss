/* pages/settings/settings.wxss */
.page-container {
  min-height: 100vh;
  background-color: var(--bg-secondary);
  padding: 20rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.card {
  background-color: var(--bg-color);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  transition: background-color 0.2s;
}

.settings-item:active {
  background-color: var(--bg-secondary);
}

.item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.icon-wrapper {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-secondary);
  border-radius: 12rpx;
}

.item-icon {
  font-size: 32rpx;
}

.item-text {
  font-size: 30rpx;
  color: var(--text-primary);
}

.item-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.item-value {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.arrow-wrapper {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
}

.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 0 30rpx;
}

/* 底部信息 */
.footer {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
  text-align: center;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.8;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 100%;
  background-color: var(--bg-color);
  border-radius: 32rpx 32rpx 0 0;
  padding: 30rpx;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--text-tertiary);
}

.modal-body {
  flex: 1;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding-top: 20rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

/* 输入区域样式 */
.input-section {
  margin-bottom: 30rpx;
}

.import-hint {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.format-example {
  background-color: var(--bg-secondary);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.format-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  display: block;
}

.format-content {
  font-size: 24rpx;
  color: var(--text-secondary);
  white-space: pre-line;
  line-height: 1.6;
  display: block;
}

.import-textarea {
  width: 100%;
  height: 300rpx;
  padding: 20rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-color);
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.parse-btn {
  background: linear-gradient(135deg, var(--primary-gradient-start) 0%, var(--primary-gradient-end) 100%);
  color: white;
  font-size: 30rpx;
  border-radius: 16rpx;
  border: none;
}

.parse-btn::after {
  border: none;
}

/* 解析结果 */
.result-section {
  margin-top: 20rpx;
}

.result-header {
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
}

.result-tip {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
  display: block;
}

.course-list {
  max-height: 400rpx;
}

.course-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: var(--bg-secondary);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.course-info {
  flex: 1;
}

.course-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.course-detail {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 4rpx;
}

.course-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
}

.course-actions {
  display: flex;
  gap: 20rpx;
}

.course-edit {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--secondary-gradient-start);
}

.course-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--danger-gradient-start);
}

.result-tip {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
  display: block;
}

/* 编辑弹窗样式 */
.edit-modal .modal-body {
  max-height: 70vh;
}

.edit-form {
  padding: 20rpx 0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-color);
  box-sizing: border-box;
}

.picker-value {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-color);
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

/* 格式说明 */
.format-tips {
  background-color: var(--bg-color);
  padding: 20rpx;
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.tips-item {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 底部按钮 */
.cancel-btn {
  flex: 1;
  background-color: var(--bg-color);
  color: var(--text-secondary);
  font-size: 30rpx;
  border-radius: 16rpx;
  border: none;
}

.cancel-btn::after {
  border: none;
}

.confirm-btn {
  flex: 1;
  background: linear-gradient(135deg, var(--primary-gradient-start) 0%, var(--primary-gradient-end) 100%);
  color: white;
  font-size: 30rpx;
  border-radius: 16rpx;
  border: none;
}

.confirm-btn::after {
  border: none;
}

/* 课程时间设置弹窗样式 */
.schedule-settings-modal .modal-body {
  max-height: 60vh;
}

.time-list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.header-text {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.header-tip {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.time-list {
  max-height: 400rpx;
  margin-bottom: 20rpx;
}

.time-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: var(--bg-secondary);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.lesson-number {
  width: 100rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.time-display {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.time-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.edit-icon {
  font-size: 28rpx;
  color: var(--primary-gradient-start);
}

.time-edit {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 10rpx;
}

.time-input {
  width: 120rpx;
  height: 60rpx;
  padding: 0 10rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  background-color: var(--bg-color);
  text-align: center;
}

.time-separator {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.edit-actions {
  display: flex;
  gap: 20rpx;
  margin-left: 10rpx;
}

.action-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border-radius: 8rpx;
}

.action-btn.save {
  color: var(--success-color, #52c41a);
}

.action-btn.cancel {
  color: var(--danger-gradient-start);
}

.delete-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 40rpx;
  color: var(--danger-gradient-start);
}

.add-lesson-section {
  margin: 20rpx 0;
  text-align: center;
}

.add-lesson-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 40rpx;
  background-color: var(--bg-secondary);
  border: 2rpx dashed var(--border-color);
  border-radius: 16rpx;
}

.add-icon {
  font-size: 36rpx;
  color: var(--primary-gradient-start);
}

.add-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.max-lesson-tip {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.time-settings-tips {
  background-color: var(--bg-secondary);
  padding: 20rpx;
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.time-settings-tips .tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  display: block;
}

.time-settings-tips .tips-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  display: block;
}
