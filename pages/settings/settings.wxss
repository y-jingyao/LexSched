/* pages/settings/settings.wxss */
page {
  background-color: #f5f7fa;
}

.page-container {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  backdrop-filter: blur(10rpx);
}

.avatar-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 分区标题 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
  font-weight: 500;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 设置项 */
.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  transition: background-color 0.2s;
}

.settings-item:active {
  background-color: #f9f9f9;
}

.item-left {
  display: flex;
  align-items: center;
}

/* 图标包装器 */
.icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.icon-wrapper.blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.icon-wrapper.green {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.icon-wrapper.orange {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.icon-wrapper.purple {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.item-icon {
  font-size: 32rpx;
}

.item-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.item-right {
  display: flex;
  align-items: center;
}

.item-value {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}

.arrow-wrapper {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 300;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin-left: 118rpx;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #bbb;
}
