/**index.wxss**/
page {
  background-color: #f5f7fa;
  height: 100%;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f7fa;
}

/* 头部样式 */
.header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-sizing: border-box;
  flex-shrink: 0;
}

.header-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  flex-wrap: nowrap;
}

.header-right {
  display: flex;
  align-items: center;
}

.add-btn {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #52e97a 0%, #4cb628 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(79, 228, 173, 0.4);
}

.week-info {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  white-space: nowrap;
}

.week-num {
  font-size: 24rpx;
  color: #666;
  background-color: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.date-info {
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
}

/* 日历行样式 */
.calendar-row {
  width: 100%;
  display: flex;
  align-items: center;
  background-color: #f5f7fa;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
  box-sizing: border-box;
  flex-shrink: 0;
}

.month {
  width: 60rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
  writing-mode: vertical-rl;
}

.day-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.week-day {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.day-num {
  font-size: 28rpx;
  color: #333;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
}

.day-cell.today .day-num {
  background-color: #333;
  color: #fff;
}

.day-cell.today .week-day {
  color: #333;
  font-weight: bold;
}

/* 滚动区域 */
.scroll {
  flex: 1;
  background-color: #f5f7fa;
  overflow: scroll;
}

.timetable-container {
  display: flex;
  height: 1440rpx;
  background-color: #f5f7fa;
  min-width: 780rpx;
}

/* 左侧时间列 */
.time-column {
  width: 80rpx;
  background-color: #f5f7fa;
  padding-left: 10rpx;
}

.time-slot {
  height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  padding-top: 10rpx;
  box-sizing: border-box;
}

.lesson-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.start-time {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

.end-time {
  font-size: 18rpx;
  color: #999;
  margin-top: 2rpx;
}

/* 课程网格 */
.course-grid {
  flex: 1;
  position: relative;
  display: flex;
  min-width: 700rpx;
}

.grid-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background-color: #e8e8e8;
}

/* 课程卡片 */
.course-card {
  position: absolute;
  width: 90rpx;
  border-radius: 16rpx;
  padding: 12rpx 8rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.course-name {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
  line-height: 1.3;
  word-break: break-all;
}

.course-teacher {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

.course-location {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

.course-weeks {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
  padding: 2rpx 0;
}

/* 非本周课程 */
.not-current-week {
  opacity: 0.8;
}

.not-current-week-tag {
  font-size: 16rpx;
  color: #fff;
  background-color: rgba(0, 0, 0, 0.3);
  padding: 2rpx 6rpx;
  border-radius: 6rpx;
  margin-top: 4rpx;
  display: inline-block;
  align-self: flex-start;
}

/* 颜色选择器 */
.color-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 10rpx 0;
}

.color-tag {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  border: 4rpx solid transparent;
  box-sizing: border-box;
}

.color-tag.selected {
  border-color: #333;
  box-shadow: 0 0 0 2rpx #fff, 0 0 0 6rpx #333;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

/* 弹窗内容 */
.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 85%;
  max-width: 650rpx;
  background-color: #fff;
  border-radius: 24rpx;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  max-height: 85vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 30rpx;
  max-height: 65vh;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

/* 详情视图 */
.detail-view {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
}

.detail-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.detail-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

/* 表单视图 */
.form-view {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.form-input {
  height: 80rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
}

.form-picker {
  height: 80rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
}

.weeks-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 10rpx 0;
}

.week-tag {
  width: 60rpx;
  height: 60rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.week-tag.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 按钮 */
.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-cancel {
  background-color: #f5f7fa;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.btn-edit {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #fff;
}

.btn-delete {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
}
